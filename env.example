# gaston_rag — variables de entorno
# Copiar a .env y completar
# Este archivo SÍ va al repositorio — .env NO

# ── Modelo LLM ───────────────────────────────────────────────────
MODEL_PROVIDER=ollama
MODEL_NAME=phi3:mini

# ── Embeddings ────────────────────────────────────────────────────
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# ── Conectores externos ──────────────────────────────────────────
GITHUB_TOKEN=
GITHUB_USERNAME=gaxoblanco
HF_TOKEN=
HF_USERNAME=gaxoblanco

# ── ChromaDB ─────────────────────────────────────────────────────
CHROMA_HOST=chroma
CHROMA_PORT=8000

# ── Ollama ───────────────────────────────────────────────────────
OLLAMA_HOST=ollama
OLLAMA_PORT=11434

# ── Provider de modelo ────────────────────────────────────────────────────────
# "ollama" | "huggingface"
MODEL_PROVIDER=ollama

# ── HuggingFace Inference API ─────────────────────────────────────────────────
# Modelo a usar cuando MODEL_PROVIDER=huggingface
HF_INFERENCE_MODEL=meta-llama/Llama-3.1-8B-Instruct

GASTON_RAG_API_KEY=